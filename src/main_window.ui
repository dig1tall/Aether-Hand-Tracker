            <property name="styleSheet">
             <string notr="true">QPushButton#btn_info {
    /* Глубокий темный синий фон */
    background-color: rgba(25, 35, 45, 220); 
    
    /* Стальная обводка */
    border: 2px solid #a0a0a0; 
    border-radius: 10px;
    
    /* Шрифт из твоего проекта */
    color: #e0e0e0;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
    font-weight: bold;
     /* Делаем капсом, как в Start */
    
    padding: 8px 20px;
}

/* При наведении — переходим в холодный синий/голубой */
QPushButton#btn_info:hover {
    background-color: rgba(30, 70, 110, 180); 
    border-color: #00dfff; /* Яркий голубой акцент */
    color: #ffffff;
}

/* Состояние, когда вкладка открыта */
QPushButton#btn_info[active=&quot;true&quot;] {
    border: 2px solid #00dfff;
    background-color: rgba(30, 70, 110, 100);
    color: #ffffff;
}

/* Эффект нажатия (Инверсия) */
QPushButton#btn_info:pressed {
    background-color: #e0e0e0;
    color: #000000;
}</string>
            </property>
