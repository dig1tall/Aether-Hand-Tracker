            <property name="styleSheet">
             <string notr="true">QPushButton#btn_quit {
    /* Глубокий темный красный фон */
    background-color: rgba(60, 20, 20, 220); 
    
    /* Стальная обводка */
    border: 2px solid #a0a0a0; 
    border-radius: 10px;
    
    /* Шрифт */
    color: #e0e0e0;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
    font-weight: bold;
    
    padding: 8px 20px;
}



/* Состояние, когда вкладка активна */
QPushButton#btn_quit[active=&quot;true&quot;] {
    border: 2px solid #ff4d4d;
    background-color: rgba(110, 30, 30, 100);
    color: #ffffff;
}

/* Эффект нажатия (Инверсия в светлый/белый) */
QPushButton#btn_quit:pressed {
    background-color: #ff4d4d;
    color: #ffffff;
    border-color: #ffffff;
}
#btn_quit:hover {
    background-color: rgba(255, 50, 50, 40);
    border: 1px solid #FF3232;
    color: #FF3232;
}
</string>
