            <property name="styleSheet">
             <string notr="true">/* Базовое состояние (Зеленоватый неон) */
QPushButton {
    /* Фон остается константным */
    background-color: rgba(62, 25, 80, 150); 
    
    /* Зеленый неон для текста и границ */
    border: 2px solid #deff9a;
    color: #deff9a;
    
    border-radius: 10px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
    font-weight: bold;
    padding: 8px 20px;
}

/* Состояние STOP (Меняем только обводку и текст на красный) */
QPushButton[active=&quot;true&quot;] {
    border: 2px solid #ff4d4d;
    color: #ff4d4d;
    /* background-color не пишем, чтобы он наследовался из блока выше */
}

/* Эффект при наведении (можно сделать чуть ярче фон) */
QPushButton:hover {
    background-color: rgba(90, 35, 110, 180);
}

/* Эффект нажатия */
QPushButton:pressed {
    background-color: #deff9a;
    color: #000000;
}</string>
