            <item>
             <widget class="QCheckBox" name="check_draw_skeleton">
              <property name="layoutDirection">
               <enum>Qt::RightToLeft</enum>
              </property>
              <property name="styleSheet">
               <string notr="true">/* Сам текст чекбокса */
QCheckBox {
    color: #E0E0E0;
    spacing: 10px;   /* Расстояние до квадратика */
    /* Укажи здесь шрифт, который у тебя на кнопках. Обычно это Segoe UI или Arial */
background-color: transparent;
color: #E0E0E0;
font-family: &quot;Segoe UI&quot;;
font-size: 11px;
font-weight: bold;
text-transform: uppercase;
border: none;
}

/* Состояние текста, когда включено */
QCheckBox:checked {
    color: #2D8C5A; /* Тот самый спокойный зеленый */
    font-weight: bold; /* Можно сделать жирным, чтобы выделялось */
}

/* Базовое состояние квадратика */
QCheckBox::indicator {
    width: 22px;
    height: 22px;
    border: 1px solid #555555;
    border-radius: 5px;
    background-color: rgba(30, 30, 30, 200);
}

/* Состояние индикатора, когда включено */
QCheckBox::indicator:checked {
    background-color: #2D8C5A;
    border-color: #2D8C5A;
    image: url(data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0ibm9uZSIgc3Ryb2tlPSJ3aGl0ZSIgc3Ryb2tlLXdpZHRoPSIzIiBzdHJva2UtbGluZWNhcD0icm91bmQiIHN0cm9rZS1saW5lam9pbj0icm91bmQiPjxwYXRoIGQ9Ik0yMCA2TDkgMTdsLTUtNSIvPjwvc3ZnPg==);
}

/* Наведение на квадратик */
QCheckBox::indicator:hover {
    border-color: #2D8C5A;
}</string>
