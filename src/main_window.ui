            <property name="styleSheet">
             <string notr="true">QPushButton#btn_settings {
    /* Тот же темный фон, но чуть более серый оттенок для отличия */
    background-color: rgba(30, 30, 35, 220); 
    
    /* Стальная обводка */
    border: 2px solid #a0a0a0; 
    border-radius: 10px;
    
    /* Копируем шрифт из твоего кода */
    color: #e0e0e0;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
    font-weight: bold; /* Или поставь 900, если у Start так */
    /* letter-spacing: 4px; — добавь, если у Start буквы &quot;раздвинуты&quot; */
    
    padding: 8px 20px;
}

/* При наведении */
QPushButton#btn_settings:hover {
    background-color: rgba(90, 35, 110, 180); /* Тот же эффект наведения */
    border-color: #ffffff;
    color: #ffffff;
}

/* Активное состояние (Test Mode ON) */
QPushButton#btn_settings[active=&quot;true&quot;] {
    border: 2px solid #ffffff; /* Белая обводка при тесте */
    color: #ffffff;
}

/* Эффект нажатия (Инверсия как у основной) */
QPushButton#btn_settings:pressed {
    background-color: #e0e0e0;
    color: #000000;
}</string>
            </property>
